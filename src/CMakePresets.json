{
    "version": 3,
    "configurePresets": [
        {
            "name": "STM32",
            "displayName": "🛠️ Build Firmware (ARM)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/stm32",
            "toolchainFile": "${sourceDir}/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "OFF"
            }
        },
        {
            "name": "HOST",
            "displayName": "🧪 Build tests and doc (default to Linux CI)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/host",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "ON",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "firmware",
            "configurePreset": "STM32",
            "displayName": "🚀 Build firmware"
        },
        {
            "name": "tests",
            "configurePreset": "HOST",
            "displayName": "⚙️ Build untests"
        },
        {
            "name": "doc",
            "configurePreset": "HOST",
            "displayName": "📚 Build the documentation",
            "targets": [
                "doc"
            ]
        }
    ]
}