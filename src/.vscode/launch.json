{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (ST-Link)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/stm32/EtherBench.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "stlink",
            "device": "STM32H563ZI",
            "interface": "swd",
            "v1": false,
            "svdFile": "${workspaceFolder}/STM32H563.svd",
            "preLaunchTask": "CMake: build",
            "serverArgs": [
                "-m",
                "1", // Select core one. Why ? I don't know. But, I know.
            ],
            "postStartSessionCommands": [
                "sharedlibrary",
                "symbol-file C:/dev/EtherBench/src/build/EtherBench.elf",
                "set substitute-path /build/gnu-tools-for-stm32_14.3.rel1.20251027-0700/src/newlib C:/ST/STM32CubeIDE_2.1.0/STM32CubeIDE/plugins/com.st.stm32cube.ide.mcu.externaltools.gnu-tools-for-stm32.14.3.rel1.win32_1.0.0.202510270700/tools/arm-none-eabi/src",
                "set substitute-path C:/dev/EtherBench/src ${workspaceFolder}",
                "set confirm off",
            ],
        }
    ]
}